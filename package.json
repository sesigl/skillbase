{
  "private": true,
  "name": "skillbase",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=25.9.0"
  },
  "scripts": {
    "prepare": "husky",
    "verify": "node --import tsx scripts/verify.ts",
    "qa": "pnpm --filter @skillbase/core qa && pnpm --filter @skillbase/landing-page qa",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "husky": "9.1.7",
    "tsx": "4.22.4"
  }
}
