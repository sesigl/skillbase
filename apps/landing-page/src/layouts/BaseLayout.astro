---
import '@fontsource-variable/geist';
import '@fontsource-variable/space-grotesk';
import '@fontsource/jetbrains-mono';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Skillbase — governance and analytics for AI coding skills</title>
    <meta name="description" content="Skillbase is a governance and analytics tool for AI coding skills. Point it at your GitHub plugin repo, see what skills exist, who uses them, and whether they measurably improve outcomes." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-[var(--bg)] text-[var(--fg)] font-sans antialiased">
    <slot />
  </body>
</html>
