---
interface Props {
  indexError?: string;
  indexResult?: {
    status: 'valid' | 'invalid';
    skills: unknown[];
    validationErrors: { file: string; message: string }[];
    warnings: string[];
  };
}

const { indexError, indexResult } = Astro.props;
---

<form method="post" class="mb-8">
  <input type="hidden" name="_action" value="index" />

  <div class="flex gap-3">
    <input
      type="text"
      name="path"
      placeholder="/path/to/your-skills-repo"
      autocomplete="off"
      class="input flex-1 px-4 py-3"
      required
    />
    <button type="submit" class="btn-primary px-5 py-3 shrink-0">
      index
    </button>
  </div>
</form>

{
  indexError && (
    <div class="mb-8 rounded-lg border border-[var(--danger)] bg-[var(--danger-wash)] p-4">
      <p class="font-mono text-xs text-[var(--danger)]">{indexError}</p>
    </div>
  )
}

{
  indexResult && (
    <div class={`mb-8 rounded-lg border p-4 ${indexResult.status === 'valid' ? 'border-[var(--success)] bg-[var(--success-wash)]' : 'border-[var(--danger)] bg-[var(--danger-wash)]'}`}>
      <p class={`font-mono text-xs font-semibold ${indexResult.status === 'valid' ? 'text-[var(--success)]' : 'text-[var(--danger)]'}`}>
        {indexResult.status === 'valid'
          ? `Indexed ${indexResult.skills.length} skill${indexResult.skills.length !== 1 ? 's' : ''}`
          : 'Indexing failed'}
      </p>

      {
        indexResult.validationErrors.length > 0 && (
          <ul class="mt-3 space-y-1">
            {indexResult.validationErrors.map((err) => (
              <li class="font-mono text-2xs text-[var(--fg-faint)]">
                <span class="text-[var(--danger)]">{err.file}</span>: {err.message}
              </li>
            ))}
          </ul>
        )
      }

      {
        indexResult.warnings.length > 0 && (
          <ul class="mt-3 space-y-1">
            {indexResult.warnings.map((w) => (
              <li class="font-mono text-2xs text-[var(--warning)]">{w}</li>
            ))}
          </ul>
        )
      }
    </div>
  )
}
