---
const { value } = Astro.props;
---

<form method="get" action="/" class="relative mb-10">
  <input
    type="text"
    name="search"
    value={value}
    placeholder="Search skills..."
    class="input px-4 py-3"
    autofocus
  />
  <button
    type="submit"
      class="absolute right-2 top-1/2 -translate-y-1/2 rounded-md border border-[var(--border)] bg-[var(--accent)] px-4 py-1.5 font-sans text-xs font-semibold text-[var(--fg-onaccent)] transition-all hover:bg-[var(--accent-hover)] active:scale-[0.98]"
  >
    search
  </button>
</form>
