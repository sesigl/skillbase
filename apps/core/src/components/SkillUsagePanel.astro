---
import type { SkillUsage } from '@lib/statistics/domain/skill-invocation/SkillInvocationRepository';

const { usage } = Astro.props as { usage: SkillUsage };

const hasUsage = usage.totalInvocations > 0;
const dailyTotal = usage.dailyCounts.reduce((total, day) => total + day.count, 0);
const maxDailyCount = Math.max(1, ...usage.dailyCounts.map((day) => day.count));
const formatNumber = new Intl.NumberFormat('en-US');
const formatDay = new Intl.DateTimeFormat('en-US', {
  day: 'numeric',
  month: 'short',
  timeZone: 'UTC',
});
const formatFullDay = new Intl.DateTimeFormat('en-US', {
  day: 'numeric',
  month: 'short',
  timeZone: 'UTC',
  weekday: 'short',
  year: 'numeric',
});
const formatTimestamp = new Intl.DateTimeFormat('en-US', {
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  month: 'short',
  timeZone: 'UTC',
  timeZoneName: 'short',
  year: 'numeric',
});
const firstDay = formatChartDay(usage.dailyCounts[0]?.date);
const lastDay = formatChartDay(usage.dailyCounts.at(-1)?.date);
const lastUsed = usage.lastUsedAt ? formatTimestamp.format(usage.lastUsedAt) : 'No usage recorded';

const metrics = [
  { label: 'Invocations', value: usage.totalInvocations },
  { label: 'Native loads', value: usage.nativeInvocations },
  { label: 'File reads', value: usage.fileReadInvocations },
  { label: 'Known users', value: usage.knownUsers },
  { label: 'Sessions', value: usage.sessions },
  { label: 'Unassigned', value: usage.unassignedInvocations },
];
const yAxisTicks = Array.from(new Set([maxDailyCount, Math.ceil(maxDailyCount / 2), 0])).map((value) => ({
  position: Math.round((value / maxDailyCount) * 100),
  value,
}));
const dailyChartData = usage.dailyCounts.map((day) => {
  const countLabel = `${formatNumber.format(day.count)} ${day.count === 1 ? 'invocation' : 'invocations'}`;

  return {
    ...day,
    ariaLabel: `${formatChartFullDay(day.date)}: ${countLabel}`,
    countLabel,
    height: day.count === 0 ? 0 : Math.max(8, Math.round((day.count / maxDailyCount) * 100)),
    shortDate: formatChartDay(day.date),
  };
});

function formatChartDay(date: string | undefined): string {
  if (!date) return '';
  return formatDay.format(new Date(`${date}T00:00:00.000Z`));
}

function formatChartFullDay(date: string | undefined): string {
  if (!date) return '';
  return formatFullDay.format(new Date(`${date}T00:00:00.000Z`));
}
---

<section class="card overflow-hidden">
  <div class="grid gap-0 lg:grid-cols-[minmax(0,1fr)_19rem]">
    <div class="p-6 lg:p-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <p class="font-mono text-2xs font-medium uppercase tracking-[var(--tracking-caps)] text-[var(--accent-text)]">
            Usage telemetry
          </p>
          <h2 class="mt-3 font-display text-2xl font-semibold tracking-[var(--tracking-tight)] text-[var(--fg)]">
            Adoption signal
          </h2>
          <p class="mt-3 max-w-[58ch] text-sm leading-relaxed text-[var(--fg-muted)]">
            Native loads and skill file accesses recorded for <code class="font-mono text-[var(--fg)]">{usage.skillName}</code>.
            User identity is counted only when telemetry includes <code class="font-mono text-[var(--fg)]">user.id</code>.
          </p>
        </div>
        <div class="rounded-lg border border-[var(--border)] bg-[var(--bg-sunk)] px-3 py-2 text-right">
          <span class="block font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--fg-faint)]">Last used</span>
          <span class="mt-1 block font-mono text-xs text-[var(--fg)]">{lastUsed}</span>
        </div>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {metrics.map((metric) => (
          <div class="rounded-lg border border-[var(--border)] bg-[var(--bg-sunk)] p-4">
            <p class="font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--fg-faint)]">{metric.label}</p>
            <p class="mt-2 font-mono text-2xl font-semibold tracking-[var(--tracking-tight)] text-[var(--fg)]">
              {formatNumber.format(metric.value)}
            </p>
          </div>
        ))}
      </div>

      <div class="mt-6 rounded-lg border border-[var(--border)] bg-[var(--surface-2)] p-4">
        <div class="flex items-baseline justify-between gap-4">
          <h3 class="font-display text-lg font-semibold tracking-[var(--tracking-snug)] text-[var(--fg)]">30-day usage</h3>
          <span class="font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--fg-faint)]">Daily count</span>
        </div>

        {dailyTotal > 0 ? (
          <div class="mt-5">
            <div class="grid grid-cols-[2.75rem_minmax(0,1fr)] gap-3">
              <div class="relative h-36 font-mono text-2xs text-[var(--fg-faint)]" aria-hidden="true">
                {yAxisTicks.map((tick) => (
                  <span class="absolute right-0 translate-y-1/2" style={`bottom: ${tick.position}%`}>
                    {formatNumber.format(tick.value)}
                  </span>
                ))}
              </div>

              <div>
                <div class="relative h-36 border-b border-[var(--border)]" aria-label="Daily invocation chart">
                  <div class="pointer-events-none absolute inset-x-0 inset-y-0">
                    {yAxisTicks.map((tick) => (
                      <span class="absolute inset-x-0 border-t border-[var(--border)] opacity-50" style={`bottom: ${tick.position}%`}></span>
                    ))}
                  </div>

                  <div class="relative z-10 flex h-full items-end gap-1">
                    {dailyChartData.map((day) => (
                      <div
                        class="group relative flex h-full min-w-2 flex-1 items-end rounded-sm focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-[var(--ring)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--surface-2)]"
                        role="img"
                        tabindex="0"
                        aria-label={day.ariaLabel}
                      >
                        <div
                          class="w-full rounded-t-sm bg-[var(--accent)] opacity-75 transition-opacity duration-[var(--dur-fast)] ease-[var(--ease-out)] group-hover:opacity-100"
                          style={`height: ${day.height}%`}
                        ></div>
                        <span class="pointer-events-none absolute bottom-full left-1/2 z-10 mb-2 hidden -translate-x-1/2 whitespace-nowrap rounded-md border border-[var(--border)] bg-[var(--surface)] px-2 py-1 font-mono text-2xs text-[var(--fg)] shadow-sm group-hover:block group-focus-visible:block">
                          {day.shortDate}: {day.countLabel}
                        </span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
            <div class="mt-3 grid grid-cols-[2.75rem_minmax(0,1fr)] gap-3 font-mono text-2xs text-[var(--fg-faint)]">
              <span aria-hidden="true"></span>
              <div class="flex justify-between gap-4">
                <span>{firstDay}</span>
                <span>{lastDay}</span>
              </div>
            </div>
          </div>
        ) : (
          <p class="mt-5 text-sm leading-relaxed text-[var(--fg-muted)]">
            {hasUsage ? 'No activity was recorded in the last 30 days.' : 'No usage has been recorded for this skill yet.'}
          </p>
        )}
      </div>
    </div>

    <aside class="border-t border-[var(--border)] bg-[var(--code-bg)] p-6 lg:border-l lg:border-t-0">
      <p class="font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--code-line)]">
        User breakdown
      </p>

      {usage.perUserCounts.length > 0 ? (
        <div class="mt-5 overflow-x-auto">
          <table class="w-full min-w-[32rem] border-collapse text-left">
            <thead>
              <tr class="border-b border-[var(--code-border)]">
                <th class="py-2 pr-4 font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--code-line)]">User</th>
                <th class="py-2 pr-4 font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--code-line)]">Invocations</th>
                <th class="py-2 pr-4 font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--code-line)]">Native</th>
                <th class="py-2 pr-4 font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--code-line)]">Reads</th>
              </tr>
            </thead>
            <tbody>
              {usage.perUserCounts.map((user) => (
                <tr class="border-b border-[var(--code-border)] last:border-0">
                  <td class="py-3 pr-4 font-mono text-xs text-[var(--code-fg)]">{user.userId}</td>
                  <td class="py-3 pr-4 font-mono text-xs text-[var(--lime-300)]">{formatNumber.format(user.totalInvocations)}</td>
                  <td class="py-3 pr-4 font-mono text-xs text-[var(--code-line)]">{formatNumber.format(user.nativeInvocations)}</td>
                  <td class="py-3 pr-4 font-mono text-xs text-[var(--code-line)]">{formatNumber.format(user.fileReadInvocations)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="mt-5 text-sm leading-relaxed text-[var(--fg-onink)]">
          No telemetry records include <code class="font-mono text-[var(--lime-300)]">user.id</code> yet. Sessions are shown as runtime context, not users.
        </p>
      )}

      <div class="mt-6 space-y-3 border-t border-[var(--code-border)] pt-5">
        <div class="flex items-center justify-between gap-4">
          <span class="font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--code-line)]">Native</span>
          <span class="font-mono text-xs text-[var(--code-fg)]">{formatNumber.format(usage.nativeInvocations)}</span>
        </div>
        <div class="flex items-center justify-between gap-4">
          <span class="font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--code-line)]">File reads</span>
          <span class="font-mono text-xs text-[var(--code-fg)]">{formatNumber.format(usage.fileReadInvocations)}</span>
        </div>
        <div class="flex items-center justify-between gap-4">
          <span class="font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--code-line)]">Sessions</span>
          <span class="font-mono text-xs text-[var(--code-fg)]">{formatNumber.format(usage.sessions)}</span>
        </div>
      </div>
    </aside>
  </div>
</section>
