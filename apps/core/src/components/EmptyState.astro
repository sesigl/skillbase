---
interface Props {
  query?: string;
  noRepos?: boolean;
  missingRepos?: string[];
}

const { query, noRepos = false, missingRepos = [] } = Astro.props;
---

<div class="flex flex-col items-center justify-center py-16 text-center">
  <div class="flex size-[52px] items-center justify-center rounded-lg bg-[var(--surface-2)]">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--fg-faint)]">
      {noRepos || missingRepos.length > 0 ? (
        <path d="M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-6l-2-2H5a2 2 0 0 0-2 2Z" />
      ) : (
        <>
          <path d="M10.5 10.5 21 21" />
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </>
      )}
    </svg>
  </div>

  {noRepos ? (
    <>
      <p class="mt-3 font-display text-lg font-semibold text-[var(--fg)]">
        No repositories indexed
      </p>
      <p class="mt-1.5 max-w-[42ch] text-sm leading-relaxed text-[var(--fg-muted)]">
        Index a local Claude Code skills repository to get started. The repo needs a <code class="rounded-xs border border-[var(--border)] bg-[var(--accent-wash)] px-1.5 py-px font-mono text-[var(--text-xs)] text-[var(--accent-text)]">.claude/skills/</code> directory with <code class="rounded-xs border border-[var(--border)] bg-[var(--accent-wash)] px-1.5 py-px font-mono text-[var(--text-xs)] text-[var(--accent-text)]">SKILL.md</code> files.
      </p>
    </>
  ) : missingRepos.length > 0 ? (
    <>
      <p class="mt-3 font-display text-lg font-semibold text-[var(--fg)]">
        No skills found
      </p>
      <p class="mt-1.5 max-w-[42ch] text-sm leading-relaxed text-[var(--fg-muted)]">
        Previously indexed repositories are no longer available.
      </p>
      <div class="mt-4 max-w-[52ch] w-full">
        <p class="font-mono text-2xs text-[var(--fg-faint)] mb-2">Missing repositories</p>
        {missingRepos.map((repo: string) => (
          <p class="font-mono text-xs text-[var(--accent-text)] truncate py-0.5">{repo}</p>
        ))}
      </div>
    </>
  ) : (
    <>
      <p class="mt-3 font-display text-lg font-semibold text-[var(--fg)]">
        No skills match that search
      </p>
      <p class="mt-1.5 max-w-[42ch] text-sm leading-relaxed text-[var(--fg-muted)]">
        Nothing for <code class="rounded-xs border border-[var(--border)] bg-[var(--accent-wash)] px-1.5 py-px font-mono text-[var(--text-xs)] text-[var(--accent-text)]">{query}</code> yet. Try a broader term.
      </p>
    </>
  )}
</div>
