---
const { skill } = Astro.props;
---

<article class="card p-6 hover:-translate-y-px">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <h3 class="font-mono text-base font-semibold text-[var(--fg)]">
        <span class="text-[var(--accent-text)]">{skill.name}</span>
        <span class="text-[var(--fg-muted)]">@</span>
        {skill.author}
      </h3>
      <p class="mt-2 text-sm text-[var(--fg-muted)] leading-relaxed line-clamp-2">
        {skill.description}
      </p>
    </div>
    <span class="tag shrink-0">
      v{skill.version}
    </span>
  </div>

  <div class="mt-4 flex flex-wrap gap-2">
    {skill.tags.map((tag: string) => (
      <span class="tag">
        {tag}
      </span>
    ))}
  </div>

  <div class="mt-3 flex flex-wrap gap-1.5">
    {skill.providers.map((provider: string) => (
      <span class="tag rounded-md bg-[var(--surface-2)] text-[var(--fg-faint)]">
        {provider}
      </span>
    ))}
  </div>
</article>
