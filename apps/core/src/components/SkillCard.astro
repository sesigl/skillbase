---
import { toBase64Url } from '@lib/catalog/infrastructure/adapters/url-encoding';
import type { Skill } from '@lib/catalog/domain/skill/Skill';
import type { SkillUsageOverview } from '@lib/statistics/domain/skill-invocation/SkillInvocationRepository';

const { skill, usage } = Astro.props as { skill: Skill; usage?: SkillUsageOverview };

const href = `/skill/${toBase64Url(skill.sourceRepository)}/${skill.name}`;
const uniqueUsers = usage?.uniqueUsersLast30Days ?? 0;
const invocations = usage?.invocationsLast30Days ?? 0;
const formatNumber = new Intl.NumberFormat('en-US');
const userLabel = uniqueUsers === 1 ? 'user' : 'users';
const invocationLabel = invocations === 1 ? 'invocation' : 'invocations';
---

<a href={href} class="card block p-6 hover:-translate-y-px no-underline focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-[var(--ring)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg)]">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div class="min-w-0">
      <h3 class="font-mono text-base font-semibold">
        <span class="text-[var(--accent-text)]">{skill.name}</span>
      </h3>
      <p class="mt-1 font-mono text-2xs text-[var(--fg-faint)] truncate" title={skill.sourceRepository}>
        {skill.sourceRepository}
      </p>
      <p class="mt-2 text-sm text-[var(--fg-muted)] leading-relaxed line-clamp-2">
        {skill.description}
      </p>
    </div>
    <aside class="flex shrink-0 flex-row items-center gap-3 sm:flex-col sm:items-end">
      <div class="text-left sm:text-right">
        <span class="block font-mono text-xs text-[var(--fg-faint)]">
          <span class:list={[uniqueUsers > 0 ? 'font-semibold text-[var(--accent-text)]' : 'text-[var(--fg-faint)]']}>
            {formatNumber.format(uniqueUsers)} {userLabel}
          </span>
          <span class="px-1 text-[var(--fg-faint)]">·</span>
          <span>{formatNumber.format(invocations)} {invocationLabel}</span>
        </span>
        <span class={`tag mt-2 shrink-0 ${skill.userInvocable ? 'border-[var(--green-600)] text-[var(--green-600)]' : 'border-[var(--amber-600)] text-[var(--amber-600)]'}`}>
          {skill.userInvocable ? 'user-invocable' : 'model-invocation-disabled'}
        </span>
      </div>
    </aside>
  </div>

  {skill.tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {skill.tags.map((tag: string) => (
        <span class="tag">
          {tag}
        </span>
      ))}
    </div>
  )}

  {skill.providers.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {skill.providers.map((provider: string) => (
        <span class="tag rounded-md bg-[var(--surface-2)] text-[var(--fg-faint)]">
          {provider}
        </span>
      ))}
    </div>
  )}
</a>
