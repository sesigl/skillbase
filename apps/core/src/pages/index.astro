---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import SkillList from '../components/SkillList.astro';
import EmptyState from '../components/EmptyState.astro';
import IndexForm from '../components/IndexForm.astro';
import RepositoryList from '../components/RepositoryList.astro';
import type { Skill } from '@lib/catalog/domain/skill/Skill';
import type { IndexedRepository, RepositoryScanResult } from '@lib/catalog/domain/repository-registry/IndexedRepository';
import type { SkillUsageOverview } from '@lib/statistics/domain/skill-invocation/SkillInvocationRepository';
import { parseSkillSort, sortSkillsForBrowse } from '@lib/catalog/presentation/sortSkillsForBrowse';
import { actions } from 'astro:actions';

const search = Astro.url.searchParams.get('search') || '';
const sort = parseSkillSort(Astro.url.searchParams.get('sort'));

let skills: Skill[] = [];
let repositories: IndexedRepository[] = [];
let usageBySkillName: Record<string, SkillUsageOverview> = {};
let dbError = false;
let missingRepos: string[] = [];
let noRepos = true;
let indexResult: RepositoryScanResult | undefined;
let indexError: string | undefined;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action')?.toString();

  try {
    if (action === 'index') {
      const { data, error } = await Astro.callAction(actions.indexRepository, formData);
      if (error) {
        indexError = error.message;
      } else {
        indexResult = data;
      }
    } else if (action === 'remove') {
      const { error } = await Astro.callAction(actions.removeRepository, formData);
      if (error) throw new Error(error.message);
    } else if (action === 'clear-all') {
      const { error } = await Astro.callAction(actions.clearAll, formData);
      if (error) throw new Error(error.message);
    }
  } catch (err) {
    if (action === 'index') {
      indexError = err instanceof Error ? err.message : 'Indexing failed';
    }
  }
}

try {
  const { createCatalogUseCases } = await import('@lib/catalog/infrastructure/di');
  const { createStatisticsUseCases } = await import('@lib/statistics/infrastructure/di');
  const catalog = createCatalogUseCases();
  const statistics = createStatisticsUseCases();
  skills = search ? await catalog.searchSkills(search) : await catalog.browseSkills();
  usageBySkillName = Object.fromEntries((await statistics.getSkillUsageOverview()).map((usage) => [usage.skillName, usage]));
  skills = sortSkillsForBrowse(skills, usageBySkillName, sort);
  repositories = await catalog.listRepositories();
  missingRepos = repositories.filter((r) => r.lastStatus === 'missing').map((r) => r.path);
  noRepos = repositories.length === 0;
} catch {
  dbError = true;
}
---

<BaseLayout>
  <main class="container-content py-16">
    <header class="mb-12">
      <h1 class="font-display text-[var(--text-3xl)] font-semibold tracking-[-0.02em]">
        skillbase
      </h1>
      <p class="mt-2 font-mono text-sm text-[var(--fg-muted)]">
        governance and analytics for AI coding skills
      </p>
    </header>

    <IndexForm indexError={indexError} indexResult={indexResult} />

    {
      dbError ? (
        <EmptyState noRepos={true} />
      ) : (
        <>
          <SearchBar value={search} sort={sort} />

          <RepositoryList repositories={repositories} />

          {
            missingRepos.length > 0 && (
              <div class="mb-6 rounded-lg border border-[var(--warning)] bg-[var(--warning-wash)] p-4">
                <p class="font-mono text-xs text-[var(--warning)] font-semibold">
                  Some indexed repositories are no longer available.
                </p>
              </div>
            )
          }

          {skills.length > 0 ? (
            <>
              <div class="mb-4 flex flex-col gap-3 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="font-mono text-xs text-[var(--fg)]">
                    {skills.length} {skills.length === 1 ? 'skill' : 'skills'}
                  </p>
                  <p class="mt-1 font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--fg-faint)]">
                    {sort === 'users'
                      ? 'Sorted by unique users in the last 30 days'
                      : sort === 'invocations'
                        ? 'Sorted by invocations in the last 30 days'
                        : 'Sorted by name'}
                  </p>
                </div>

                <form method="get" action="/" class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row sm:items-center sm:justify-end">
                  {search && <input type="hidden" name="search" value={search} />}
                  <label for="skill-sort" class="font-mono text-2xs uppercase tracking-[var(--tracking-caps)] text-[var(--fg-faint)] sm:mr-1">
                    Sort
                  </label>
                  <select id="skill-sort" name="sort" class="input h-10 min-w-44 px-3 py-2 text-xs">
                    <option value="users" selected={sort === 'users'}>Unique users</option>
                    <option value="invocations" selected={sort === 'invocations'}>Invocations</option>
                    <option value="name" selected={sort === 'name'}>Name</option>
                  </select>
                  <button class="h-10 rounded-md border border-[var(--border)] bg-[var(--accent)] px-4 font-sans text-xs font-semibold text-[var(--fg-onaccent)] transition-all hover:bg-[var(--accent-hover)] active:scale-[0.98]">
                    Apply
                  </button>
                </form>
              </div>
              <SkillList skills={skills} usageBySkillName={usageBySkillName} />
            </>
          ) : (
            <EmptyState query={search} noRepos={noRepos} missingRepos={missingRepos} />
          )}
        </>
      )
    }
  </main>
</BaseLayout>
